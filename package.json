{
  "name": "playbacc",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @playbacc/api dev",
    "dev:web": "bun run --filter @playbacc/web dev",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun run fmt:check && bun run lint",
    "typecheck": "bun run --filter @playbacc/api typecheck && bun run --filter @playbacc/shared typecheck && bun run --filter @playbacc/web check",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^5.9.3"
  }
}
